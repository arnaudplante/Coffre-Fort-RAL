#include <Arduino.h>
#include <TM1637Display.h>
#include <Keypad.h>
#include <Servo.h>
// blibliotheques
bool boncode = false;
// verrouille le coffre
Servo myServo11;
// pin du servo
const byte CODE_LONGUEUR = 4;
//nb de characteres dans le code
byte input = 0;
// met le nombre de touches appyees a 0
const byte AFF_PROF_CLK_PIN = 2;
const byte AFF_PROF_DIO_PIN = 3;
TM1637Display display(AFF_PROF_CLK_PIN, AFF_PROF_DIO_PIN);
//pins pour display
int essai = 0;
// essais a 0
const int trigPin = 13;
const int echoPin = 12;
// pins pour ultrasonic sencor
float duration, distance;

byte a = 0;
byte b = 0;
byte c = 0;
byte d = 0;
// met les chiffres a 0
const byte ROWS = 4;
const byte COLS = 3;
const byte ROW_PINS[ROWS] = {4, 5, 6, 7};
const byte COL_PINS[COLS] = {8, 9, 10};
const char TOUCHES[ROWS][COLS] = {
  {'1','2','3'},
  {'4','5','6'},
  {'7','8','9'},
  {'*','0','#'}
};
Keypad heroKeypad = Keypad(makeKeymap(TOUCHES), ROW_PINS, COL_PINS, ROWS, COLS);
// setup pour le clavier souple
float mesurerDistance() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  float dur = pulseIn(echoPin, HIGH);
  return (dur * 0.0343) / 2;
}
// code pour distance du ultrasonic sensor
void setup() {
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
// setup pour pins ultrasonic sensor
  Serial.begin(9600);
//pour moniteur serie
  display.setBrightness(7);
  display.clear();
// reset ecran
  myServo11.attach(11);
  myServo11.write(90); 
//met les servos fermés
}

void loop() {
  distance = mesurerDistance();
// le sensor calcule la distance
  if (boncode && distance >= 11 && distance <= 13) {
    myServo11.write(0);  
// ouvre le coffre si le code est bon
  } else if (boncode) {
    myServo11.write(90); 
//sinon le coffre reste fermé
  }

  char car = heroKeypad.getKey(); // prends la touche
  if (!car) return; // si aucune touche pressee, il se passe rien

  if (car == '*') {
    input = 0;
    a = b = c = d = 0;
    display.clear();
    return;
  }

  if (car == '#') {
    if (boncode == false) {
      essai++;
      myServo11.write(90);
      a = b = c = d = 0;
      display.clear();

      if (essai >= 3) {
        byte tirets[4] = {0x40, 0x40, 0x40, 0x40};
        display.setSegments(tirets);
        delay(300000);
        essai = 0;
        display.clear();
      }
    }

    display.clear();
    a = b = c = d = 0;
    input = 0;
    boncode = false;
    return;
  }

  if (car >= '0' && car <= '9') {
    byte digit = display.encodeDigit(car - '0');
    input++;

    if (input == 1) a = digit;
    else if (input == 2) b = digit;
    else if (input == 3) c = digit;
    else if (input == 4) {
      d = digit;

      if (a == display.encodeDigit(1) &&
          b == display.encodeDigit(9) &&
          c == display.encodeDigit(4) &&
          d == display.encodeDigit(5)) {
        boncode = true;
        essai = 0; 
      } else {
        boncode = false;
      }
    }

    byte affichage[4] = {a, b, c, d};
    display.setSegments(affichage);
  }
}
