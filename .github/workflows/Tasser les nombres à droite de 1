    if (key >= '0' && key <= '9') {
      
      // 1. Shift all current digits one position to the left
      displayData[0] = displayData[1];
      displayData[1] = displayData[2];
      displayData[2] = displayData[3];
      
      // 2. Add the new digit to the rightmost position
      displayData[3] = display.encodeDigit(key - '0');
      
      // 3. Update the display
      display.setSegments(displayData);
    }
