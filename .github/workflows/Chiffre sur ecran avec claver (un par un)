#include "Arduino.h"
#include <TM1637Display.h>
#include <Keypad.h>

const byte AFF_PROF_CLK_PIN = 2;
const byte AFF_PROF_DIO_PIN = 3;

TM1637Display SUIVI_PROF(AFF_PROF_CLK_PIN, AFF_PROF_DIO_PIN);

const byte ROWS = 4;
const byte COLS = 3;

const byte ROW_PINS[ROWS] = {4, 5, 6, 7};
const byte COL_PINS[COLS] = {8, 9, 10};

const char TOUCHES[ROWS][COLS] = {
  {'1','2','3'},
  {'4','5','6'},
  {'7','8','9'},
  {'*','0','#'}
};

Keypad heroKeypad = Keypad(makeKeymap(TOUCHES), ROW_PINS, COL_PINS, ROWS, COLS);

// Tableau des segments pour les chiffres 0–9
const byte digits[10] = {
  SEG_A | SEG_B | SEG_C | SEG_D | SEG_E | SEG_F,          // 0
  SEG_B | SEG_C,                                          // 1
  SEG_A | SEG_B | SEG_D | SEG_E | SEG_G,                  // 2
  SEG_A | SEG_B | SEG_C | SEG_D | SEG_G,                  // 3
  SEG_B | SEG_C | SEG_F | SEG_G,                          // 4
  SEG_A | SEG_C | SEG_D | SEG_F | SEG_G,                  // 5
  SEG_A | SEG_C | SEG_D | SEG_E | SEG_F | SEG_G,          // 6
  SEG_A | SEG_B | SEG_C,                                  // 7
  SEG_A | SEG_B | SEG_C | SEG_D | SEG_E | SEG_F | SEG_G,  // 8
  SEG_A | SEG_B | SEG_C | SEG_D | SEG_F | SEG_G           // 9
};

void setup() {
  SUIVI_PROF.setBrightness(7);
}

void loop() {
  char car = heroKeypad.waitForKey();
  if (car == '#'){
   SUIVI_PROF.clear();  
  }
    if (car >= '0' && car <= '9') {

    byte displayBuffer[4] = {0, 0, 0, 0};  // 4 digits obligatoires
    displayBuffer[0] = digits[car - '0'];  // On place le chiffre à gauche

    SUIVI_PROF.setSegments(displayBuffer, 4);
  }
}
